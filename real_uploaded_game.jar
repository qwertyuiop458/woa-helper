<section id="landing-section" class=" ">
	
	<div class="container">
		
		<div class="content">
		
            <div id="file_upload_title_wrap" class=" flex">
                <!-- text, forms or logo before upload form  -->
                <div id="before_file_upload">

                                        
                        

                                                    <div id="main_page_top_header_1_carousel">
                                <div>
                            <h1 class="main_page_top_header_1 arrow">
                                Файлообменник и облачное хранилище
                            </h1>

                            <div class="file_types">
                                Фото
                                <div class="file_types_seperator">|</div>
                                Видео
                                <div class="file_types_seperator">|</div>
                                Аудио
                                <div class="file_types_seperator">|</div>
                                Документы
                            </div>
                        </div>
                        <h1 class="main_page_top_header_1">
                            Самый быстрый способ передачи <span>больших файлов</span>
                        </h1>
                        <h1 class="main_page_top_header_1">
                            Подпишитесь на <span>безопасное</span> хранилище и <span>более высокую</span> скорость
                        </h1>                            </div>
                                            
                </div>
                <!-- /text, forms or logo before upload form  -->

                                
                <!-- upload form -->
                <div id="upload-box-outer">
                    
                    <!-- upload form : text during file upload -->
                    <div class="upload_waiting top">
                        <div class="during_file_upload__title">
                            <img src="/images/landing/upload_cloud_red_comb.svg" alt="File upload" />Загрузка...                        </div>

                        <div>Держите браузер открытым</div>
                    </div>
                    
                    <div id="text_during_file_upload">
                        
                        <div id="during_file_upload">
                            
                                                        
                            <div id="download_link_wrapper_0">
                                <div id="download_link_0"></div>
                                <div class="copy_button_wrapper">
                                    <div id="copy_button_0" class="copy_button">
                                        <div class="copy_text">
                                            <div class="hover mobile">Копировать</div>
                                            <div class="hover">Копировать ссылку</div>
                                            <div class="copied">Copied</div>
                                        </div>
                                    </div>
                                    <div class="copy_button_drawer">
                                        <div id="drawer_copy_button_0" class="checked">
                                            <span>Скопируйте ссылку для просмотра</span>
                                            <span class="desc">Права на просмотр и загрузку</span>
                                        </div>
                                        <div id="drawer_edit_button_0">
                                            <span>Скопировать ссылку на редактирование</span>
                                            <span class="desc">Может добавлять, редактировать контент, ставить электронную подпись и удалять</span>
                                        </div>
