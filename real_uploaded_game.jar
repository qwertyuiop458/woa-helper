                pointer-events: none;\n                                        }\n                                        100% {\n                                            opacity: 0;\n                                            pointer-events: none;\n                                        }\n                                    }\n                                    @media only screen and (min-width: 772px) {\n                                        #file_upload_title_wrap.flex #before_file_upload #main_page_top_header_1_carousel > *:not(.carousel-picture) {\n                                            display: none;\n                                        }\n                                        #file_upload_title_wrap.flex #before_file_upload #main_page_top_header_1_carousel > *:nth-child(4) {\n                                            position: unset;\n                                        }\n                                        #file_upload_title_wrap.flex #before_file_upload #main_page_top_header_1_carousel > * {\n                                            pointer-events: none;\n                                            animation-name: textFaderCarousel;\n                                            animation-duration: 20s;\n                                            position: unset;\n                                        }#file_upload_title_wrap.flex #before_file_upload #main_page_top_header_1_carousel > *:nth-child(4) { \n                        animation-delay: 0s !important; \n                    }#file_upload_title_wrap.flex #before_file_upload #main_page_top_header_1_carousel > *:nth-child(5) { \n                        animation-delay: 10s !important; \n                    } } <\/style><script>setTimeout(\n                    function() {\n                        carouselAdShownIncrement('32');\n                    }, 0);setTimeout(\n                    function() {\n                        carouselAdShownIncrement('33');\n                    }, 10000);<\/script>";
    

